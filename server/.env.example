# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

# MongoDB connection string. Include the database name at the end, e.g. /task
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/task

# Secret used to sign JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Port the API listens on (optional, defaults to 3000)
PORT=3000
